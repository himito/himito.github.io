// Colors
color-default = #565a5f
color-background = #f5f8f9
color-link = #1b7498
color-border = #eceff2
color-grey = #999
color-twitter = #00aced
color-facebook = #3b5998
color-pinterest = #cb2027
color-google = #dd4b39


// Fonts
font-sans = "open sans", "Helvetica Neue", "Microsoft Yahei", Helvetica, Arial, sans-serif
font-serif = Georgia, "Times New Roman", "Microsoft Yahei", serif
font-size = 14px
font-size-h1 = 2em
font-size-h3 = 1.3em

// Lines
line-height-footer = 1.6em
line-height-title = 1.1em

// Header
logo-size = 40px
header-height = 64px

// Layout
block-margin = 40px
article-padding = 20px
main-column = 8
sidebar-column = 2
profile-column = 3

// Grid
total-width = 100%
column-width = 80px
gutter-width = 20px
columns = main-column + sidebar-column + profile-column

// Profile
profile-avatar-size = 128px
